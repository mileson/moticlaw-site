flowchart LR
  visit_home["进入官网首页<br/>用户来到首屏，看到 MotiClaw 本地运行主张、支持平台和下载按钮。"]
  open_download["点击 Download<br/>主 CTA、页头 CTA 或 Quick Start 区按钮统一打开下载弹窗。"]
  load_manifest["读取发布清单"]
  detect_platform["识别当前系统"]
  has_artifact{"是否有匹配安装包<br/>推荐项必须来自真实发布清单；缺失时展示兜底安装方式。"}
  show_recommended(["展示推荐下载卡<br/>弹窗显示版本、日期、检测系统、推荐文件名、大小、校验摘要和安装提示。"])
  show_fallback[["展示备用安装入口<br/>平台暂未发布时禁用下载按钮，给出一键安装命令、GitHub Release 或等待提示。"]]
  download_or_copy["下载或复制安装命令<br/>用户下载推荐安装包，或复制备用安装命令继续安装。"]
  visit_home -->|"看见首屏 CTA"| open_download
  open_download -->|"打开弹窗"| load_manifest
  load_manifest -->|"拿到版本与安装包数据"| detect_platform
  detect_platform -->|"匹配系统和架构"| has_artifact
  has_artifact -->|"有真实包"| show_recommended
  has_artifact -.->|"无真实包或清单失败"| show_fallback
  show_recommended -->|"点击下载"| download_or_copy
  show_fallback -->|"复制备用命令"| download_or_copy
